# 0G Chain (OG.md — exact RPC URLs)
OG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
# Bug #19 fix: Storage indexer URL must be environment-configurable (OG.md says URL can change)
OG_STORAGE_INDEXER=https://indexer-storage-testnet-standard.0g.ai
# Bug #3 fix: Provider address must be set after calling broker.inference.listService()
OG_COMPUTE_PROVIDER=0x...   # run agents/scripts/discover-provider.ts to populate

# Wallets
AGENT_PRIVATE_KEY=0x...
USER_PRIVATE_KEY=0x...
RISK_AGENT_PRIVATE_KEY=0x...

# Contracts (Base Sepolia)
POOL_MANAGER_ADDRESS=0x...
UNIVERSAL_ROUTER_ADDRESS=0x...
PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3
# Bug #20 fix: HOOK_ADDRESS must be set BEFORE building agent runtime (EIP-712 domain binding)
HOOK_ADDRESS=0x...           # set after CREATE2 salt mining, required for EIP-712
SESSION_TREASURY_ADDRESS=0x...

# Contracts (0G Testnet)
AGENT_REGISTRY_ADDRESS=0x...
AGENT_NFT_ADDRESS=0x...

# x402
X402_FACILITATOR_URL=https://facilitator.cdp.coinbase.com

# KeeperHub (Bug #11 fix — manual setup at app.keeperhub.com, no REST API)
# 1. Create workflow at app.keeperhub.com with a Webhook trigger
# 2. Add a Scheduled trigger (e.g., every 5 min) that fires the webhook
# 3. Set the KeeperHub action URL = AGENT_SERVER_URL/orchestrator/wake
KEEPERHUB_WEBHOOK_TRIGGER_URL=https://app.keeperhub.com/webhooks/...

# Uniswap API (Bug #21: only needed for /quote, not for core swap execution)
UNISWAP_API_KEY=...   # from developers.uniswap.org/dashboard — optional for swap

# Agent server
PORT=3001
AGENT_SERVER_URL=http://localhost:3001
